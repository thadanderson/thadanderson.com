---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = import.meta.glob('../content/Contact.md', { eager: true });
const { Content } = Object.values(modules)[0] as any;
---

<BaseLayout title="Contact">
  <div class="page-header">
    <h1>Contact</h1>
  </div>
  <Content />
</BaseLayout>
