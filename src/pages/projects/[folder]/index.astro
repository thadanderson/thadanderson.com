---
import BaseLayout from '../../../layouts/BaseLayout.astro';

function toSlug(name: string) {
  return name
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/&/g, 'and')
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

export async function getStaticPaths() {
  function toSlug(name: string) {
    return name
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/&/g, 'and')
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^a-z0-9-]/g, '')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  const allFiles = import.meta.glob('../../../content/Projects/**/*.md');

  const folders = new Map<string, {
    name: string;
    overview: (() => Promise<any>) | null;
    pages: { title: string; slug: string }[];
    subfolders: { name: string; slug: string }[];
  }>();

  for (const [filePath, loader] of Object.entries(allFiles)) {
    const parts = filePath.split('/');
    const projectsIdx = parts.indexOf('Projects');
    const remaining = parts.slice(projectsIdx + 1);
    if (remaining.length < 2) continue; // skip root-level files

    const folderName = remaining[0];
    const folderSlug = toSlug(folderName);

    if (!folders.has(folderSlug)) {
      folders.set(folderSlug, { name: folderName, overview: null, pages: [], subfolders: [] });
    }

    const entry = folders.get(folderSlug)!;

    if (remaining.length === 2) {
      // Direct .md child of the folder
      const pageTitle = remaining[1].replace('.md', '');
      if (pageTitle === 'Overview') {
        entry.overview = loader as () => Promise<any>;
      } else {
        entry.pages.push({ title: pageTitle, slug: toSlug(pageTitle) });
      }
    } else if (remaining.length >= 3) {
      // File inside a sub-subfolder — record the sub-subfolder once
      const subfolderName = remaining[1];
      const subfolderSlug = toSlug(subfolderName);
      if (!entry.subfolders.find((s) => s.slug === subfolderSlug)) {
        entry.subfolders.push({ name: subfolderName, slug: subfolderSlug });
      }
    }
  }

  return Array.from(folders.entries()).map(([folderSlug, data]) => ({
    params: { folder: folderSlug },
    props: {
      folderName: data.name,
      overviewLoader: data.overview,
      pages: data.pages,
      subfolders: data.subfolders,
    },
  }));
}

const { folder } = Astro.params;
const { folderName, overviewLoader, pages, subfolders } = Astro.props as {
  folderName: string;
  overviewLoader: (() => Promise<any>) | null;
  pages: { title: string; slug: string }[];
  subfolders: { name: string; slug: string }[];
};

const { Content } = overviewLoader ? await overviewLoader() : { Content: null };

const allItems = [
  ...pages.map((p) => ({ title: p.title, href: `/projects/${folder}/${p.slug}` })),
  ...subfolders.map((s) => ({ title: s.name, href: `/projects/${folder}/${s.slug}` })),
].sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title={`${folderName} — Projects`}>
  <div class="breadcrumb">
    <a href="/projects">← Projects</a>
  </div>
  <div class="page-header">
    <h1>{folderName}</h1>
  </div>
  {Content && <Content />}
  {allItems.length > 0 && (
    <ul class="content-list">
      {allItems.map((item) => (
        <li>
          <a href={item.href}>{item.title}</a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
