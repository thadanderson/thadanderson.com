---
import BaseLayout from '../../layouts/BaseLayout.astro';

function toSlug(name: string) {
  return name
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/&/g, 'and')
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}

const allFiles = import.meta.glob('../../content/Projects/**/*.md', { eager: false });
const items: { title: string; slug: string }[] = [];
const seen = new Set<string>();

for (const filePath of Object.keys(allFiles)) {
  const parts = filePath.split('/');
  const projectsIdx = parts.indexOf('Projects');
  const remaining = parts.slice(projectsIdx + 1);

  if (remaining.length === 1) {
    // Root-level .md file
    const title = remaining[0].replace('.md', '');
    const slug = toSlug(title);
    if (!seen.has(slug)) {
      seen.add(slug);
      items.push({ title, slug });
    }
  } else if (remaining.length >= 2) {
    // File inside a subfolder — represent the subfolder once
    const folderName = remaining[0];
    const folderSlug = toSlug(folderName);
    if (!seen.has(folderSlug)) {
      seen.add(folderSlug);
      items.push({ title: folderName, slug: folderSlug });
    }
  }
}

items.sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title="Projects">
  <div class="page-header">
    <h1>Projects</h1>
  </div>
  <ul class="content-list">
    {items.map((p) => (
      <li>
        <a href={`/projects/${p.slug}`}>{p.title}</a>
      </li>
    ))}
  </ul>
</BaseLayout>
