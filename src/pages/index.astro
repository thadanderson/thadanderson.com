---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = import.meta.glob('../content/Home.md', { eager: true });
const { Content } = Object.values(modules)[0] as any;
---

<BaseLayout title="Thad Anderson" description="Percussionist, composer, & arts leader">
  <div class="home-hero">
    <Content />
  </div>
</BaseLayout>

<style>
  .home-hero {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .home-hero :global(p:first-child) {
    font-size: 1.15rem;
    line-height: 1.7;
  }

  .home-hero :global(img) {
    width: 100%;
    display: block;
    border-radius: 3px;
    border: 2px solid #707070;
    box-sizing: border-box;
  }
</style>
